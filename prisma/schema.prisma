generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id         Int              @id @default(autoincrement())
  sessionKey Int              @unique
  label      String
  overview   SessionOverview?
  drivers    Driver[]
  laps       Lap[]
}

model SessionOverview {
  id         Int        @id @default(autoincrement())
  sessionId  Int        @unique
  winner     String
  totalLaps  Int
  overtakes  Int
  avgPitStop Float
  session    Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lapSeries  LapPoint[]
  pitStops   PitStop[]
  stints     Stint[]
}

model Lap {
  id              Int      @id @default(autoincrement())
  dateStart       DateTime
  driverNumber    Int
  durationSector1 Float
  durationSector2 Float
  durationSector3 Float
  i1Speed         Int
  i2Speed         Int
  isPitOutLap     Boolean
  lapDuration     Float
  lapNumber       Int
  meetingKey      Int
  meeting         Meeting  @relation(fields: [meetingKey], references: [meetingKey], onDelete: Cascade)
  segmentsSector1 Int[]
  segmentsSector2 Int[]
  segmentsSector3 Int[]
  sessionKey      Int
  session         Session  @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)
  stSpeed         Int

  @@unique([sessionKey, driverNumber, lapNumber])
}

model LapPoint {
  id         Int             @id @default(autoincrement())
  overviewId Int
  lap        Int
  norris     Float
  leclerc    Float
  overview   SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model PitStop {
  id          Int             @id @default(autoincrement())
  overviewId  Int
  driver      String
  lap         Int
  stop        Float
  compoundOut String
  overview    SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model Stint {
  id         Int             @id @default(autoincrement())
  overviewId Int
  driver     String
  lapFrom    Int
  lapTo      Int
  tyre       String
  overview   SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model CompareSnapshot {
  id          Int  @id
  drivers     Json
  metrics     Json
  deltaSeries Json
  telemetry   Json
}

model LiveSnapshot {
  id        Int  @id
  lap       Int
  positions Json
  events    Json
}

model Meeting {
  id                  Int      @id @default(autoincrement())
  circuitKey          Int
  circuitImage        String
  circuitInfoURL      String
  circuitShortName    String
  circuitType         String
  countryCode         String
  countryFlag         String
  countryKey          Int
  countryName         String
  dateEnd             DateTime
  dateStart           DateTime
  gmtOffset           Int
  location            String
  meetingKey          Int      @unique
  meetingName         String
  meetingOfficialName String
  year                Int
  drivers             Driver[]
  laps                Lap[]
}

model Driver {
  id            Int     @id @default(autoincrement())
  broadcastName String
  driverNumber  Int
  firstName     String
  fullName      String
  headshotURL   String
  lastName      String
  meetingKey    Int
  meeting       Meeting @relation(fields: [meetingKey], references: [meetingKey], onDelete: Cascade)
  nameAcronym   String
  sessionKey    Int
  session       Session @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)

  @@unique([sessionKey, driverNumber])
}
