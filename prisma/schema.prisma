generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id         Int @id @default(autoincrement())
  sessionKey Int             @unique
  label      String
  overview   SessionOverview?
  drivers Driver[]
}

model SessionOverview {
  id         Int @id @default(autoincrement())
  sessionId  Int       @unique
  winner     String
  totalLaps  Int
  overtakes  Int
  avgPitStop Float
  session    Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lapSeries  LapPoint[]
  pitStops   PitStop[]
  stints     Stint[]
}

model LapPoint {
  id         Int @id @default(autoincrement())
  overviewId Int
  lap        Int
  norris     Float
  leclerc    Float
  overview   SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model PitStop {
  id          Int @id @default(autoincrement())
  overviewId  Int
  driver      String
  lap         Int
  stop        Float
  compoundOut String
  overview    SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model Stint {
  id         Int @id @default(autoincrement())
  overviewId Int
  driver     String
  lapFrom    Int
  lapTo      Int
  tyre       String
  overview   SessionOverview @relation(fields: [overviewId], references: [id], onDelete: Cascade)
}

model CompareSnapshot {
  id          Int  @id
  drivers     Json
  metrics     Json
  deltaSeries Json
  telemetry   Json
}

model LiveSnapshot {
  id        Int  @id
  lap       Int
  positions Json
  events    Json
}

model Meeting {
  id Int @id @default(autoincrement())
  circuitKey Int @map("circuit_key") 
  circuitImage String @map("circuit_image") 
  circuitInfoURL String @map("circuit_info_url")
  circuitShortName String @map("circuit_short_name")
  circuitType String @map("circuit_type")
  countryCode String @map("country_code")
  countryFlag String @map("country_flag")
  countryKey Int @map("country_key")
  countryName String @map("country_name")
  dateEnd DateTime @map("date_end")
  dateStart DateTime @map("date_start")
  gmtOffset Int @map("gmt_offset")
  location String
  meetingKey Int @unique @map("meeting_key")
  meetingName String @map("meeting_name")
  meetingOfficialName String @map("meeting_official_name")
  year Int 
  drivers Driver[]
}

model Driver {
  id Int @id @default(autoincrement())
  broadcastName String @map("broadcast_name")
  driverNumber Int @map("driver_number")
  firstName String @map("first_name")
  fullName String @map("full_name")
  headshotURL String @map("headshot_url")
  lastName String @map("last_name")
  meetingKey Int
  meeting Meeting @relation(fields: [meetingKey], references: [meetingKey], onDelete: Cascade)
  nameAcronym String @map("name_acronym")
  sessionKey Int
  session Session @relation(fields: [sessionKey], references: [sessionKey], onDelete: Cascade)
}
